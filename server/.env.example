# --- Database ---
# Local Postgres:
# DATABASE_URL=postgresql://username:password@localhost:5432/unmadhouse
#
# Supabase (use the Session pooler connection string, port 5432):
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
# SSL is auto-enabled for supabase hosts. For any other hosted Postgres, set PGSSL=true.
DATABASE_URL=postgresql://username:password@localhost:5432/unmadhouse
# PGSSL=true

PORT=4000

# --- Auth ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- CORS (production only) ---
# Set to your deployed frontend URL, e.g. https://unmadhouse.vercel.app
# CLIENT_ORIGIN=

# --- Web Push (PWA notifications) ---
# Generate keys: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
